DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fueled_capital?schema=public"
PORT=4000

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
AWS_REGION=us-east-1

# Storage: "local" writes to ./local-storage for dev without AWS creds; "s3" uses the real bucket.
STORAGE_PROVIDER=local
S3_INVOICE_DOCS_BUCKET=
S3_KYB_DOCS_BUCKET=

# Extraction provider: "stub" always returns canned data; swap to a real provider later.
OCR_PROVIDER=stub

# Funding SLA (business days) — configurable per the brief, not hardcoded.
FUNDING_SLA_BUSINESS_DAYS=2

# Default advance percentage (configurable per broker in a later phase; global default for now).
DEFAULT_ADVANCE_PCT=95

# Shared secret Lambda handlers send as X-Internal-Api-Key to call /internal/* routes.
# Generate a real random value per environment in Phase 4 (e.g. via Terraform + Secrets Manager).
INTERNAL_API_KEY=
